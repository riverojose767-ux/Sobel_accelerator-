@file 200:
@file 201: set write_cells_ir "./find_regs_cells.json"
@file 202: set write_cells_ir [open $write_cells_ir "w"]
@file 203: puts $write_cells_ir "\["
@file 204:
@file 205: set refs [get_db [get_db lib_cells -if .is_sequential==true] .base_name]
@file 206:
@file 207: set len [llength $refs]
@file 208:
@file 209: for {set i 0} {$i < [llength $refs]} {incr i} {
            if {$i == $len - 1} {
                puts $write_cells_ir "    \"[lindex $refs $i]\""
            } else {
                puts $write_cells_ir "    \"[lindex $refs $i]\","
            }
        }
@file 216:
@file 217: puts $write_cells_ir "\]"
@file 218: close $write_cells_ir
@file 219: set write_regs_ir "./find_regs_paths.json"
@file 220: set write_regs_ir [open $write_regs_ir "w"]
@file 221: puts $write_regs_ir "\["
@file 222:
@file 223: set regs [get_db [get_db [all_registers -edge_triggered -output_pins] -if .direction==out] .name]
@file 224:
@file 225: set len [llength $regs]
@file 226:
@file 227: for {set i 0} {$i < [llength $regs]} {incr i} {
            #regsub -all {/} [lindex $regs $i] . myreg
            set myreg [lindex $regs $i]
            if {$i == $len - 1} {
                puts $write_regs_ir "    \"$myreg\""
            } else {
                puts $write_regs_ir "    \"$myreg\","
            }
        }
@file 236:
@file 237: puts $write_regs_ir "\]"
@file 238:
@file 239: close $write_regs_ir
